# Kopyala: cp scripts/.env.supabase.local.example scripts/.env.supabase.local
# Gerçek değerleri SADECE .env.supabase.local dosyasına yazın (git'e gitmez).
#
# Token: https://supabase.com/dashboard/account/tokens
SUPABASE_ACCESS_TOKEN=your_supabase_access_token_here

SUPABASE_PROJECT_REF=your_supabase_project_ref_here
MOBILE_REDIRECT=io.supabase.tatilbulucu://login-callback

# Google Cloud → APIs & Services → Credentials → OAuth 2.0 Client (Web application)
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# Facebook Developer → App ID + App Secret
FACEBOOK_APP_ID=your_facebook_app_id_here
FACEBOOK_APP_SECRET=your_facebook_app_secret_here

# Apple Sign In (opsiyonel — generate_apple_secret.py için)
# APPLE_TEAM_ID=
# APPLE_KEY_ID=
# APPLE_SERVICES_ID=
# APPLE_P8_KEY_PATH=/path/to/AuthKey_XXXXX.p8
